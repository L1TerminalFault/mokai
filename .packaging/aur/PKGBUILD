pkgname=mokai
pkgver=0.1.0
pkgrel=1
pkgdesc="A fast, minimal build system, package manager, and developer toolkit for C++"
arch=('x86_64')
url="https://github.com/L1TerminalFault/mokai"
license=('MIT')

makedepends=('cmake')

source=(
  "$pkgname-$pkgver.tar.gz::https://github.com/L1TerminalFault/mokai/archive/refs/tags/v$pkgver.tar.gz"
)

sha256sums=('25172cd9de42358054920c5fc5b1076358bed3473ce37732f029b66d6435dfa3')

build() {
  cmake -B build \
        -S . \
        -DCMAKE_BUILD_TYPE=Release \
        -DCMAKE_INSTALL_PREFIX=/usr

  cmake --build build
}

package() {
  DESTDIR="$pkgdir" cmake --install build
}
